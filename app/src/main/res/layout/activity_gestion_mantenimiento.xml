<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B8D4E8"
    tools:context=".gestion_mantenimiento">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#181143"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="Logo"
            android:src="@drawable/data_aviation"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="DatAviation"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#3949AB"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="Cerrar Sesión"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/btnPerfil"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@drawable/Perfil"
            android:scaleType="centerCrop"
            android:contentDescription="Perfil" />

    </LinearLayout>

    <!-- CONTENIDO SCROLLEABLE -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- TÍTULO GESTIÓN MANTENIMIENTO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:padding="12dp"
                    android:text="Gestión Mantenimiento"
                    android:textColor="#181143"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

            <!-- FORMULARIO PROGRAMAR MANTENIMIENTO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Aeronave -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aeronave"
                        android:textSize="13sp"
                        android:textColor="#181143"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerAeronave"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="12dp"
                        android:backgroundTint="#E8EAF6" />

                    <!-- Tipo de Inspección -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de Inspección"
                        android:textSize="13sp"
                        android:textColor="#181143"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinnerTipoInspeccion"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="12dp"
                        android:backgroundTint="#E8EAF6" />

                    <!-- Fecha Programada -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha Programada"
                        android:textSize="13sp"
                        android:textColor="#181143"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etFechaProgramada"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="dd/mm/aaaa"
                        android:inputType="date"
                        android:background="@android:color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="12dp"
                        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:textColorHint="#AAAAAA" />

                    <!-- Taller o Mecánico -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Taller o Mecánico"
                        android:textSize="13sp"
                        android:textColor="#181143"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etTallerMecanico"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Nombre del taller o mecánico"
                        android:background="@android:color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="20dp"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:textColorHint="#AAAAAA" />

                    <!-- Botón Guardar Mantenimiento -->
                    <Button
                        android:id="@+id/btnGuardarMantenimiento"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Guardar Mantenimiento"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#3949AB"
                        app:cornerRadius="24dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA DETALLE AERONAVE + CHECKLIST -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Info aeronave -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aeronave: HIK-5678"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de inspección: 100 horas"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:layout_marginBottom="10dp" />

                    <!-- Checklist -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checklist de Inspección"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#181143"
                        android:layout_marginBottom="10dp" />

                    <CheckBox
                        android:id="@+id/chkMantenimientoLinea"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mantenimiento en línea"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:buttonTint="#3949AB"
                        android:layout_marginBottom="6dp" />

                    <CheckBox
                        android:id="@+id/chkCiclosVuelo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ciclos de vuelo"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:buttonTint="#3949AB"
                        android:layout_marginBottom="6dp" />

                    <CheckBox
                        android:id="@+id/chkAeronaves"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Horas de vuelos"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:buttonTint="#3949AB"
                        android:layout_marginBottom="16dp" />

                    <!-- Botón Liberar Aeronave -->
                    <Button
                        android:id="@+id/btnLiberarAeronave"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:text="Liberar Aeronave"
                        android:textColor="#181143"
                        android:textSize="13sp"
                        android:backgroundTint="#B8D4E8"
                        app:cornerRadius="24dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BARRA DE NAVEGACIÓN INFERIOR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#181143"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#181143"
            android:src="@drawable/Casa"
            android:contentDescription="Inicio"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnNavVuelos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#181143"
            android:src="@drawable/avion"
            android:contentDescription="Vuelos"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnNavAeronaves"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#181143"
            android:src="@drawable/Registro"
            android:contentDescription="Aeronaves"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnNavConfiguracion"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#3949AB"
            android:src="@drawable/Mantenimiento"
            android:contentDescription="Configuración"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnNavPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#181143"
            android:src="@drawable/Piloto"
            android:contentDescription="Perfil"
            android:scaleType="centerInside"
            android:padding="10dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>