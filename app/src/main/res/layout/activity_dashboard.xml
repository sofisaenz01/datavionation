<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8EAF6"
    tools:context=".DashboardActivity">

    <!-- HEADER (Fijo arriba) -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#181143"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Logo"
            android:src="@drawable/data_aviation"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="DatAviation"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#3949AB"
            android:text="Salir"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />

        <ImageButton
            android:id="@+id/btnPerfil"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@drawable/perfil"
            android:contentDescription="Perfil"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <!-- CONTENIDO SCROLLEABLE -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvTituloDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:text="Dashboard General"
                android:textColor="#1A237E"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- GRID DE TARJETAS -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="4dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="4dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
                        <TextView android:text="Aeronaves" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvTotalAeronaves" android:text="12" android:textSize="24sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="4dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
                        <TextView android:text="En Vuelo" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvEnVuelo" android:text="3" android:textSize="24sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="4dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
                        <TextView android:text="Alertas" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvAlertasCriticas" android:text="2" android:textColor="#D32F2F" android:textSize="24sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_margin="4dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
                        <TextView android:text="Horas Mes" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/tvHorasMes" android:text="145" android:textSize="24sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <!-- FORMULARIO NUEVO REGISTRO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nuevo Registro Aeronave"
                        android:textAlignment="center"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Todos los campos son obligatorios"
                        android:textAlignment="center"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp"/>

                    <EditText android:id="@+id/etMatricula" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Matrícula" android:background="@drawable/edit_text_rounded" android:padding="12dp" android:layout_marginBottom="8dp" android:inputType="textCapCharacters"/>
                    <EditText android:id="@+id/etFabricante" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Fabricante" android:background="@drawable/edit_text_rounded" android:padding="12dp" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/etModelo" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Modelo" android:background="@drawable/edit_text_rounded" android:padding="12dp" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/etSerie" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Número de Serie" android:background="@drawable/edit_text_rounded" android:padding="12dp" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/etCategoria" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Categoría" android:background="@drawable/edit_text_rounded" android:padding="12dp" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/etAnio" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Año Fabricación" android:background="@drawable/edit_text_rounded" android:padding="12dp" android:layout_marginBottom="8dp" android:inputType="number"/>
                    <EditText android:id="@+id/etPesoMax" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Peso Máximo" android:background="@drawable/edit_text_rounded" android:padding="12dp" android:layout_marginBottom="8dp" android:inputType="numberDecimal"/>
                    <EditText android:id="@+id/etCarga" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Capacidad Carga" android:background="@drawable/edit_text_rounded" android:padding="12dp" android:layout_marginBottom="16dp" android:inputType="numberDecimal"/>

                    <Button
                        android:id="@+id/btnAgregarAeronave"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Agregar Aeronave"
                        android:backgroundTint="#90CAF9"
                        android:textColor="#1A237E"
                        android:paddingStart="32dp"
                        android:paddingEnd="32dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV (Fijo abajo) -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1A237E"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#3949AB"
            android:contentDescription="Inicio"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/casa" />

        <ImageButton
            android:id="@+id/btnNavVuelos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Vuelos"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/avion" />

        <ImageButton
            android:id="@+id/btnNavAeronaves"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Aeronaves"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/registro" />

        <ImageButton
            android:id="@+id/btnNavMantenimiento"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Mantenimiento"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/mantenimiento" />

        <ImageButton
            android:id="@+id/btnNavPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Perfil"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/piloto" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>