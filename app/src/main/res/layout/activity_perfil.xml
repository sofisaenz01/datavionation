<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B8D4E8"
    tools:context=".Perfil">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#181143"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="Logo"
            android:src="@drawable/data_aviation"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="DatAviation"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Mi perfil"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/btnPerfil"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@drawable/perfil"
            android:scaleType="centerCrop"
            android:contentDescription="Perfil" />

    </LinearLayout>

    <!-- CONTENIDO SCROLLEABLE -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- TÍTULO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:padding="12dp"
                    android:text="Bienvenido a tu perfil"
                    android:textColor="#181143"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

            <!-- TARJETA FORMULARIO DE PERFIL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nombre completo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre completo:"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="[Editable]"
                        android:textSize="13sp"
                        android:textColor="#222222"
                        android:background="@android:color/transparent"
                        android:paddingBottom="6dp"
                        android:layout_marginBottom="12dp"
                        android:inputType="textPersonName" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="12dp" />

                    <!-- Apellido -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apellido:"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etApellido"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="[Editable]"
                        android:textSize="13sp"
                        android:textColor="#222222"
                        android:background="@android:color/transparent"
                        android:paddingBottom="6dp"
                        android:layout_marginBottom="12dp"
                        android:inputType="textPersonName" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="12dp" />

                    <!-- Correo electrónico -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Correo electrónico:"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etCorreo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="[ejemplo@dominio.com]"
                        android:textSize="13sp"
                        android:textColor="#222222"
                        android:background="@android:color/transparent"
                        android:paddingBottom="6dp"
                        android:layout_marginBottom="12dp"
                        android:inputType="textEmailAddress" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="12dp" />

                    <!-- Número de teléfono -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Número de teléfono:"
                        android:textSize="13sp"
                        android:textColor="#444444"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="[Opcional]"
                        android:textSize="13sp"
                        android:textColor="#222222"
                        android:background="@android:color/transparent"
                        android:paddingBottom="6dp"
                        android:layout_marginBottom="20dp"
                        android:inputType="phone" />

                    <!-- BOTONES -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnGuardarCambios"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Guardar Cambios"
                            android:textColor="#181143"
                            android:textSize="11sp"
                            android:backgroundTint="#B8D4E8"
                            app:cornerRadius="18dp" />

                        <Button
                            android:id="@+id/btnCancelar"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Cancelar"
                            android:textColor="#181143"
                            android:textSize="11sp"
                            android:backgroundTint="#B8D4E8"
                            app:cornerRadius="18dp" />

                        <Button
                            android:id="@+id/btnAtras"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Atrás"
                            android:textColor="#181143"
                            android:textSize="11sp"
                            android:backgroundTint="#B8D4E8"
                            app:cornerRadius="18dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BARRA DE NAVEGACIÓN INFERIOR -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1A237E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#3949AB"
            android:src="@drawable/Casa"
            android:contentDescription="Inicio"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnNavVuelos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#181143"
            android:contentDescription="Vuelos"
            android:scaleType="centerInside"
            android:src="@drawable/avion"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnNavAeronaves"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#181143"
            android:src="@drawable/Registro"
            android:contentDescription="Aeronaves"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnNavMantenimiento"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#181143"
            android:src="@drawable/Mantenimiento"
            android:contentDescription="Configuración"
            android:scaleType="centerInside"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnNavPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#181143"
            android:src="@drawable/Piloto"
            android:contentDescription="Perfil"
            android:scaleType="centerInside"
            android:padding="10dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>